---
import styles from "./Footer.module.css";
---

<footer class={styles.footer}>
  <div class={styles.inner}>
    <div class={styles.brand}>
      <span class={styles.logoScript}>Étoile</span>
      <span class={styles.logoSub}>Gastronomie Française</span>
    </div>
    <div class={styles.divider} aria-hidden="true"></div>
    <div class={styles.meta}>
      <p class={styles.copy}>&copy; 2025 ÉTOILE. All rights reserved.</p>
      <p class={styles.disclaimer}>This is a sample website for design presentation purposes.</p>
    </div>
  </div>
</footer>
