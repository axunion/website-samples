---
import styles from "./Header.module.css";
---

<header id="site-header" class={styles.header}>
  <div class={styles.inner}>
    <a href="#" class={styles.logo} aria-label="ÉTOILE — トップページへ">
      <span class={styles.logoScript}>Étoile</span>
      <span class={styles.logoSub}>Gastronomie</span>
    </a>
    <a href="#reservation" class={styles.reservationBtn} aria-label="ご予約はこちら">
      <span class={styles.btnEn}>Reservation</span>
      <span class={styles.btnJa}>ご予約</span>
    </a>
  </div>
</header>
