---
import styles from "./Hero.module.css";
---

<section class={styles.hero}>
  <div class={styles.imageWrap}>
    <img
      src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1920&h=1080&fit=crop&q=85"
      alt="キャンドルの光に照らされた芸術的な料理が並ぶ高級レストランのテーブル"
      class={styles.image}
      loading="eager"
      onerror="this.removeAttribute('onerror');this.setAttribute('src','data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22%3E%3ClinearGradient id=%22g%22 x2=%221%22 y2=%221%22%3E%3Cstop stop-color=%22%230d1a30%22/%3E%3Cstop offset=%221%22 stop-color=%22%23050c1a%22/%3E%3C/linearGradient%3E%3Crect width=%22100%25%22 height=%22100%25%22 fill=%22url(%23g)%22/%3E%3C/svg%3E')"
    />
    <div class={styles.overlay}></div>
  </div>

  <div class={styles.content}>
    <div class={styles.ornament} aria-hidden="true">
      <svg width="100" height="20" viewBox="0 0 100 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="0" y1="10" x2="36" y2="10" stroke="#D4AF37" stroke-width="0.5" opacity="0.65"/>
        <circle cx="50" cy="10" r="3.5" stroke="#D4AF37" stroke-width="0.5" opacity="0.65" fill="none"/>
        <line x1="64" y1="10" x2="100" y2="10" stroke="#D4AF37" stroke-width="0.5" opacity="0.65"/>
      </svg>
    </div>
    <h1 class={styles.headline}>
      <span class={styles.headlineEn}>Étoile</span>
      <span class={styles.headlineJa}>
        至高の一皿と、<br />記憶に残るひとときを。
      </span>
    </h1>
    <p class={styles.sub}>Gastronomie Française à Tokyo — Azabu-Juban</p>
  </div>

  <a href="#concept" class={styles.scrollIndicator} aria-label="下へスクロール">
    <span class={styles.scrollLine}></span>
    <span class={styles.scrollText}>Scroll</span>
  </a>
</section>
