---
import styles from "./Header.module.css";

interface Props {
  active?: string;
  variant?: "light" | "dark";
}
const { active = "", variant = "light" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header id="site-header" class={styles.header} data-variant={variant}>
  <a href={`${base}forma/`} class={styles.logo}>FORMA</a>

  <nav class={styles.nav} aria-label="Main navigation">
    <a
      href={`${base}forma/philosophy/`}
      class={`${styles.link} ${active === "philosophy" ? styles.current : ""}`}
    >Philosophy</a>
    <a
      href={`${base}forma/programs/`}
      class={`${styles.link} ${active === "programs" ? styles.current : ""}`}
    >Programs</a>
    <a
      href={`${base}forma/company/`}
      class={`${styles.link} ${active === "company" ? styles.current : ""}`}
    >Company</a>
    <a
      href={`${base}forma/inquiry/`}
      class={`${styles.link} ${styles.linkInquiry} ${active === "inquiry" ? styles.current : ""}`}
    >Inquiry</a>
  </nav>

  <button
    class={styles.menuBtn}
    id="forma-menu-btn"
    aria-label="メニューを開く"
    aria-expanded="false"
    aria-controls="forma-mobile-nav"
  >
    <span class={styles.bar}></span>
    <span class={styles.bar}></span>
    <span class={styles.bar}></span>
  </button>
</header>

<div id="forma-mobile-nav" class={styles.mobileNav} aria-hidden="true">
  <button class={styles.mobileClose} id="forma-mobile-close" aria-label="閉じる">
    <span class={styles.closeBar}></span>
    <span class={styles.closeBar}></span>
  </button>
  <nav class={styles.mobileNavInner}>
    <a href={`${base}forma/`} class={styles.mobileLink}>Home</a>
    <a href={`${base}forma/philosophy/`} class={styles.mobileLink}>Philosophy</a>
    <a href={`${base}forma/programs/`} class={styles.mobileLink}>Programs</a>
    <a href={`${base}forma/company/`} class={styles.mobileLink}>Company</a>
    <a href={`${base}forma/inquiry/`} class={styles.mobileLink}>Inquiry</a>
  </nav>
</div>

<script>
  const header = document.getElementById("site-header");
  const menuBtn = document.getElementById("forma-menu-btn");
  const closeBtn = document.getElementById("forma-mobile-close");
  const mobileNav = document.getElementById("forma-mobile-nav");

  if (header) {
    const sentinel = document.createElement("div");
    sentinel.style.cssText =
      "position:absolute;top:100px;left:0;width:1px;height:1px;pointer-events:none";
    document.body.prepend(sentinel);
    new IntersectionObserver(([entry]) => {
      header.toggleAttribute("data-scrolled", !entry.isIntersecting);
    }).observe(sentinel);
  }

  function openMenu() {
    if (!mobileNav || !menuBtn) return;
    mobileNav.setAttribute("data-open", "");
    mobileNav.removeAttribute("aria-hidden");
    menuBtn.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!mobileNav || !menuBtn) return;
    mobileNav.removeAttribute("data-open");
    mobileNav.setAttribute("aria-hidden", "true");
    menuBtn.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  menuBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  mobileNav?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));
</script>
