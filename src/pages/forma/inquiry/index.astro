---
import Footer from "../_components/Footer.astro";
import Header from "../_components/Header.astro";
import styles from "./index.module.css";

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inquiry — ご照会・ご連絡 | FORMA</title>
    <meta
      name="description"
      content="FORMAへのご連絡・ご照会。ご紹介制・完全審査制にてご案内しております。"
    />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header active="inquiry" variant="light" />

    <main>
      <!-- Page Hero -->
      <section class={styles.pageHero}>
        <div class={styles.pageHeroInner}>
          <span class={styles.pageLabel}>Inquiry</span>
          <span class={styles.pageHeroRule} aria-hidden="true"></span>
          <h1 class={styles.pageHeroTitle}>ご照会・ご連絡</h1>
        </div>
      </section>

      <!-- Intro -->
      <section class={styles.intro}>
        <div class={styles.introInner} data-reveal>
          <span class={styles.sectionEn}>By Introduction Only</span>
          <span class={styles.sectionRule} aria-hidden="true"></span>
          <h2 class={styles.introTitle}>ご紹介・ご審査制について</h2>
          <p class={styles.introText}>
            FORMAのプログラムは、既存のお客様、または当社認定パートナーホテルのコンシェルジュを通じたご紹介のみにて承っております。直接のご応募には対応しておりませんが、お問い合わせの内容によっては、担当者より個別にご連絡申し上げる場合がございます。
          </p>
          <p class={styles.introText}>
            ご照会をいただいた後、担当者より一週間以内にご連絡差し上げます。なお、すべてのご回答をお約束するものではございませんことを、あらかじめご了承ください。
          </p>
        </div>
      </section>

      <!-- Contact Form -->
      <section class={styles.form}>
        <div class={styles.formInner} data-reveal>
          <header class={styles.formHeader}>
            <span class={styles.sectionEn}>Contact Form</span>
            <span class={styles.sectionRule} aria-hidden="true"></span>
            <h2 class={styles.formTitle}>お問い合わせフォーム</h2>
          </header>

          <form class={styles.contactForm} novalidate>
            <div class={styles.fieldGroup}>
              <label class={styles.label} for="name">
                お名前
                <span class={styles.required} aria-label="必須">*</span>
              </label>
              <input
                class={styles.input}
                type="text"
                id="name"
                name="name"
                autocomplete="name"
                required
                placeholder="山田 太郎"
              />
            </div>

            <div class={styles.fieldGroup}>
              <label class={styles.label} for="email">
                メールアドレス
                <span class={styles.required} aria-label="必須">*</span>
              </label>
              <input
                class={styles.input}
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                placeholder="your@email.com"
              />
            </div>

            <div class={styles.fieldGroup}>
              <label class={styles.label} for="referrer">
                ご紹介者のお名前
                <span class={styles.optional}>（任意）</span>
              </label>
              <input
                class={styles.input}
                type="text"
                id="referrer"
                name="referrer"
                placeholder="ご紹介者のお名前またはご施設名"
              />
            </div>

            <div class={styles.fieldGroup}>
              <label class={styles.label} for="message">
                お問い合わせの内容
                <span class={styles.required} aria-label="必須">*</span>
              </label>
              <textarea
                class={`${styles.input} ${styles.textarea}`}
                id="message"
                name="message"
                rows={6}
                required
                placeholder="ご要望やご質問をお聞かせください。"
              ></textarea>
            </div>

            <div class={styles.formFooter}>
              <p class={styles.privacyNote}>
                ご記入いただいた情報は厳格な守秘義務のもとで管理いたします。
              </p>
              <button type="submit" class={styles.submitBtn}>
                お問い合わせを送る
                <span aria-hidden="true" class={styles.btnArrow}>→</span>
              </button>
            </div>
          </form>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<script>
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const revealEls = Array.from(document.querySelectorAll<HTMLElement>("[data-reveal]"));

  if (reducedMotion) {
    revealEls.forEach((el) => el.setAttribute("data-visible", ""));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.setAttribute("data-visible", "");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    revealEls.forEach((el) => observer.observe(el));
  }
</script>
