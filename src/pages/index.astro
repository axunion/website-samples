---
import { Image } from "astro:assets";
import styles from "./index.module.css";
import luminaFitHero from "./lumina-fit/_assets/hero-landscape.jpg";

const samples = [
  { href: "/lumina-fit/", name: "LUMINA FIT", img: luminaFitHero },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>website-samples</title>
  </head>
  <body class={styles.body}>
    <ul class={styles.grid} role="list">
      {
        samples.map((s) => (
          <li>
            <a href={s.href} class={styles.tile}>
              <Image
                src={s.img}
                alt=""
                width={800}
                height={800}
                class={styles.img}
              />
              <span class={styles.title}>{s.name}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </body>
</html>
