---
import styles from "./index.module.css";

const samples = [
  {
    href: "/lumina-fit/",
    name: "LUMINA FIT",
    imgSrc:
      "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&h=800&fit=crop&q=80",
  },
  {
    href: "/still/",
    name: "STILL",
    imgSrc:
      "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&h=800&fit=crop&q=80",
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>website-samples</title>
  </head>
  <body class={styles.body}>
    <ul class={styles.grid} role="list">
      {
        samples.map((s) => (
          <li>
            <a href={s.href} class={styles.tile}>
              <img
                src={s.imgSrc}
                alt=""
                width="800"
                height="800"
                class={styles.img}
                onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22%3E%3ClinearGradient id=%22g%22 x2=%221%22 y2=%221%22%3E%3Cstop stop-color=%22%23d6d4d0%22/%3E%3Cstop offset=%221%22 stop-color=%22%23b8b4ae%22/%3E%3C/linearGradient%3E%3Crect width=%22100%25%22 height=%22100%25%22 fill=%22url(%23g)%22/%3E%3C/svg%3E'"
              />
              <span class={styles.title}>{s.name}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </body>
</html>
