---
import styles from "./About.module.css";
---

<section class={styles.section} id="about" aria-labelledby="about-heading">
  <div class={styles.inner}>
    <div class={styles.header} data-reveal>
      <p class={styles.label}>About GAZEN</p>
      <h2 class={styles.title} id="about-heading">一流を、誠実に。</h2>
      <p class={styles.desc}>
        雅膳は、接待・記念日・顔合わせなど、格式と品格が求められる席のために、<br />
        厳選された高級和食店の予約・案内を承る専門サービスです。
      </p>
    </div>

    <div class={styles.pillars} data-reveal data-delay="1">
      <div class={styles.pillar}>
        <div class={styles.pillarMark} aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="0.5" opacity="0.25"/>
            <path d="M24 10L27.5 18.5H36.5L29.5 23.5L32.5 32L24 27L15.5 32L18.5 23.5L11.5 18.5H20.5L24 10Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
          </svg>
        </div>
        <p class={styles.pillarEn}>Curation</p>
        <h3 class={styles.pillarJa}>厳選</h3>
        <p class={styles.pillarText}>掲載は完全招待制。コンシェルジュが実際に訪れ、料理・空間・接客の三つを審査した名店のみをご紹介します。</p>
      </div>

      <div class={styles.pillar}>
        <div class={styles.pillarMark} aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="0.5" opacity="0.25"/>
            <path d="M24 11C24 11 35 15.5 35 23.5C35 31.5 28.5 36.5 24 39C19.5 36.5 13 31.5 13 23.5C13 15.5 24 11 24 11Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            <path d="M19 24L22 27L30 20" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <p class={styles.pillarEn}>Discretion</p>
        <h3 class={styles.pillarJa}>品格</h3>
        <p class={styles.pillarText}>接待・顔合わせ・記念日——格式ある場の作法と心遣いを熟知した担当が、その席にふさわしい一軒を選び抜きます。</p>
      </div>

      <div class={styles.pillar}>
        <div class={styles.pillarMark} aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="0.5" opacity="0.25"/>
            <circle cx="24" cy="18" r="5.5" stroke="currentColor" stroke-width="1.2"/>
            <path d="M11 40C11 33.92 16.93 29 24 29C31.07 29 37 33.92 37 40" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <p class={styles.pillarEn}>Concierge</p>
        <h3 class={styles.pillarJa}>一任</h3>
        <p class={styles.pillarText}>お問い合わせから当日のご来店まで、専任コンシェルジュが誠実にお世話します。紹介状や特別手配もご相談ください。</p>
      </div>
    </div>
  </div>
</section>
