---
import styles from "./Hero.module.css";
import SearchBar from "./SearchBar.astro";
---

<section class={styles.hero} id="top">
  <div class={styles.imageWrap}>
    <img
      src="https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=1920&h=1080&fit=crop&q=85"
      alt="霧の中に連なる朱塗りの鳥居"
      class={styles.image}
      loading="eager"
      onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22%3E%3ClinearGradient id=%22g%22 x2=%221%22 y2=%221%22%3E%3Cstop stop-color=%22%23181410%22/%3E%3Cstop offset=%221%22 stop-color=%22%230a0a0a%22/%3E%3C/linearGradient%3E%3Crect width=%22100%25%22 height=%22100%25%22 fill=%22url(%23g)%22/%3E%3C/svg%3E'"
    />
    <div class={styles.overlay}></div>
  </div>

  <div class={styles.content}>
    <div class={styles.ornament} aria-hidden="true">
      <svg width="180" height="18" viewBox="0 0 180 18" fill="none">
        <line x1="0" y1="9" x2="76" y2="9" stroke="#c9a96e" stroke-width="0.5" opacity="0.45"/>
        <rect x="84" y="5" width="8" height="8" fill="none" stroke="#c9a96e" stroke-width="0.7" opacity="0.65" transform="rotate(45 88 9)"/>
        <line x1="100" y1="9" x2="180" y2="9" stroke="#c9a96e" stroke-width="0.5" opacity="0.45"/>
      </svg>
    </div>

    <p class={styles.tagline}>Curated Japanese Fine Dining</p>

    <h1 class={styles.headline}>
      <span class={styles.headlineMain}>
        本物の一流を知る、<br />大人の食体験へ。
      </span>
      <span class={styles.headlineSub}>
        A sanctuary for those who seek the finest Japanese dining —<br />
        Kappo, Sushi, Kaiseki, and beyond.
      </span>
    </h1>

    <div class={styles.searchWrap}>
      <SearchBar />
    </div>
  </div>

  <a href="#curated" class={styles.scroll} aria-label="下へスクロール">
    <span class={styles.scrollLine}></span>
    <span class={styles.scrollText}>Scroll</span>
  </a>
</section>
