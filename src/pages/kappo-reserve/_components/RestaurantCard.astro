---
import styles from "./RestaurantCard.module.css";

interface Restaurant {
  name: string;
  category: string;
  area: string;
  stars?: number;
  bib?: boolean;
  founded?: string;
  price: string;
  features: string[];
  desc: string;
  img: string;
  imgAlt: string;
}

interface Props {
  restaurant: Restaurant;
  href: string;
}

const { restaurant: r, href } = Astro.props;
---

<a href={href} class={styles.card}>
  <div class={styles.cardImageWrap}>
    <img
      src={r.img}
      alt={r.imgAlt}
      class={styles.cardImg}
      loading="lazy"
      onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22%3E%3ClinearGradient id=%22g%22 x2=%221%22 y2=%221%22%3E%3Cstop stop-color=%22%231c1814%22/%3E%3Cstop offset=%221%22 stop-color=%22%2310100e%22/%3E%3C/linearGradient%3E%3Crect width=%22100%25%22 height=%22100%25%22 fill=%22url(%23g)%22/%3E%3C/svg%3E'"
    />
    <div class={styles.cardBadges}>
      {r.stars && r.stars > 0 && (
        <span class={styles.badgeMichelin}>
          {"★".repeat(r.stars)} Michelin
        </span>
      )}
      {r.bib && <span class={styles.badgeMichelin}>Bib Gourmand</span>}
      {r.founded && <span class={styles.badgeFeature}>{r.founded}</span>}
      {r.features.slice(0, 1).map((f) => (
        <span class={styles.badgeFeature}>{f}</span>
      ))}
    </div>
  </div>
  <div class={styles.cardBody}>
    <div class={styles.cardMeta}>
      <span class={styles.cardCategory}>{r.category}</span>
      <span class={styles.cardArea}>{r.area}</span>
    </div>
    <h3 class={styles.cardName}>{r.name}</h3>
    <p class={styles.cardDesc}>{r.desc}</p>
    <div class={styles.cardFooter}>
      <span class={styles.cardPrice}>{r.price}</span>
      <span class={styles.cardLink}>
        詳細を見る
        <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
          <path d="M1 4h10M7 1l3 3-3 3" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>
</a>
