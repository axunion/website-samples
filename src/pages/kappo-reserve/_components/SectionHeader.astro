---
import styles from "./SectionHeader.module.css";

interface Props {
  label: string;
  title: string;
  titleId: string;
  href: string;
}

const { label, title, titleId, href } = Astro.props;
---

<div class={styles.sectionHeader} data-reveal>
  <div class={styles.sectionMeta}>
    <span class={styles.sectionLabel}>{label}</span>
    <h2 class={styles.sectionTitle} id={titleId}>{title}</h2>
  </div>
  <a href={href} class={styles.seeAll}>
    すべて見る
    <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
      <path d="M1 5h12M8 1l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</div>
