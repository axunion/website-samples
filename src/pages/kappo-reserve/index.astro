---
import { ClientRouter } from "astro:transitions";
import About from "./_components/About.astro";
import Concierge from "./_components/Concierge.astro";
import Curated from "./_components/Curated.astro";
import Footer from "./_components/Footer.astro";
import Guide from "./_components/Guide.astro";
import Header from "./_components/Header.astro";
import Hero from "./_components/Hero.astro";
import Reveal from "./_components/Reveal.astro";
import styles from "./index.module.css";

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>雅膳 GAZEN — 本物の一流を知る大人へ、高級和食予約サービス</title>
    <meta
      name="description"
      content="料亭・割烹・高級鮨など、厳選された日本の一流店をご案内する予約サービス「雅膳 GAZEN」。接待・会食・記念日・顔合わせに最適な一軒を、プロのコンシェルジュがご提案します。"
    />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <ClientRouter />
  </head>
  <body>
    <div class={styles.root}>
      <Header />
      <main>
        <Hero />
        <Curated />
        <About />
        <Guide />
        <Concierge />
      </main>
      <Footer />
    </div>
  </body>
</html>
<Reveal />
