---
import { ClientRouter } from "astro:transitions";
import Footer from "../_components/Footer.astro";
import Header from "../_components/Header.astro";
import Reveal from "../_components/Reveal.astro";
import ChefProfile from "./_components/ChefProfile.astro";
import CourseMenu from "./_components/CourseMenu.astro";
import Gallery from "./_components/Gallery.astro";
import InfoPanel from "./_components/InfoPanel.astro";
import ReservationForm from "./_components/ReservationForm.astro";
import styles from "./index.module.css";

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>銀座 鮨 碧天 — ミシュラン三つ星・完全紹介制 | 雅膳 GAZEN</title>
    <meta
      name="description"
      content="銀座の地下に佇む、ミシュラン三つ星の江戸前鮨「碧天」。宮田義雄が手掛けるカウンター8席のみの完全紹介制。おまかせコース¥55,000〜。GAZENよりご予約承ります。"
    />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <ClientRouter />
  </head>
  <body>
    <div class={styles.root}>
      <Header />
      <main>
        <Gallery />
        <ChefProfile />
        <CourseMenu />
        <InfoPanel />
        <ReservationForm />
      </main>
      <Footer />
    </div>
  </body>
</html>
<Reveal />
