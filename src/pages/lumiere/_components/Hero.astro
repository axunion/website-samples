---
import styles from "./Hero.module.css";
---

<section class={styles.hero} id="hero">
  <div class={styles.bg}></div>

  <div class={styles.content}>
    <p class={styles.eyebrow}>Premium Hospitality Management</p>
    <h1 class={styles.title}>LUMIÈRE</h1>
    <p class={styles.taglineJa}>光の先に、静寂がある。</p>
    <div class={styles.goldLine}></div>
    <p class={styles.taglineEn}><em>The Art of Invisible Excellence</em></p>
  </div>

  <div class={styles.scroll} aria-hidden="true">
    <span class={styles.scrollText}>Scroll</span>
    <div class={styles.scrollLine}></div>
  </div>
</section>
