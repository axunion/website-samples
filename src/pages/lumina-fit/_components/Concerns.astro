---
import base from "../index.module.css";
import styles from "./Concerns.module.css";

const concerns = [
  "運動を始めたいけれど、何を選べばいいかわからない",
  "ジムやヨガに通っても、なかなか長続きしない",
  "自分のペースで、無理なくきれいに整えたい",
];
---

<section class:list={[base.section, styles.concerns]}>
  <div class={base.container}>
    <header class:list={[base.sectionHeader]} data-reveal>
      <span class={base.secLabel}>Concerns</span>
      <h2 class={base.secHeading}>こんなお悩みありませんか？</h2>
    </header>

    <ul class={styles.list}>
      {
        concerns.map((text, i) => (
          <li
            class={styles.item}
            data-reveal
            style={`--reveal-delay: ${(i + 1) * 0.1}s`}
          >
            <span class={styles.icon} aria-hidden="true">
              <svg
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                width="14"
                height="14"
              >
                <path
                  d="M16 5L8 13l-4-4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
            <span class={styles.text}>{text}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
