---
import base from "../index.module.css";
import styles from "./Hero.module.css";

const heroPortraitSrc =
  "https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=828&h=1472&fit=crop&q=80";
const heroLandscapeSrc =
  "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&h=1080&fit=crop&q=80";
---

<section class={styles.hero} aria-labelledby="hero-heading">
  <!-- Background -->
  <div class={styles.bg} aria-hidden="true">
    <picture>
      <!-- Portrait crop for mobile (< 768px) -->
      <source media="(max-width: 767px)" srcset={heroPortraitSrc} />
      <!-- Landscape for tablet and up -->
      <img
        src={heroLandscapeSrc}
        alt=""
        class={styles.bgImg}
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
        onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22%3E%3ClinearGradient id=%22g%22 x2=%221%22 y2=%221%22%3E%3Cstop stop-color=%22%231e1b18%22/%3E%3Cstop offset=%221%22 stop-color=%22%232a2520%22/%3E%3C/linearGradient%3E%3Crect width=%22100%25%22 height=%22100%25%22 fill=%22url(%23g)%22/%3E%3C/svg%3E'"
      />
    </picture>
    <div class={styles.overlay}></div>
  </div>

  <!-- Content -->
  <div class:list={[base.container, styles.content]}>
    <h1 class={styles.heading} id="hero-heading" data-reveal>
      <span class={styles.headingEn}>LUMINA FIT</span>
      <span class={styles.rule} aria-hidden="true"></span>
      <span class={styles.headingJa}>
        わたしを整える、<br />新しい習慣。
      </span>
    </h1>
    <p class={styles.sub} data-reveal style="--reveal-delay: 0.15s">
      ヨガ・ピラティス・ジムがこれひとつで。
    </p>
    <button
      class:list={[base.ctaBtn, styles.heroCta]}
      data-cta
      type="button"
      data-reveal
      style="--reveal-delay: 0.3s"
    >
      体験予約
    </button>
  </div>

  <!-- Scroll indicator -->
  <div class={styles.scrollHint} aria-hidden="true">
    <span class={styles.scrollLabel}>Scroll</span>
    <span class={styles.scrollLine}></span>
  </div>
</section>
