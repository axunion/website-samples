---
import base from "../index.module.css";
import styles from "./Program.module.css";

const programs = [
  {
    id: "yoga",
    label: "ヨガ",
    title: "Yoga",
    desc: "呼吸と姿勢を整え、心身をゆるやかにリセット。初心者から経験者まで、自分のペースで深めることができます。",
    stars: "★★☆☆☆",
    starsLabel: "強度 2 / 5",
    imgSrc:
      "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=900&h=506&fit=crop&q=80",
    imgAlt: "静かなスタジオでヨガを行う女性",
  },
  {
    id: "pilates",
    label: "ピラティス",
    title: "Pilates",
    desc: "インナーマッスルに働きかけ、しなやかな姿勢へ導く。専用マシンを使い、体の深部から整えます。",
    stars: "★★★☆☆",
    starsLabel: "強度 3 / 5",
    imgSrc:
      "https://images.unsplash.com/photo-1518611012118-696072aa579a?w=900&h=506&fit=crop&q=80",
    imgAlt: "マシンピラティスをするスタジオの様子",
  },
  {
    id: "gym",
    label: "ジム",
    title: "Gym",
    desc: "最新マシンで効率よくボディメイク。トレーニングの目的や体力に合わせて、自分だけのプログラムを組めます。",
    stars: "★★★★☆",
    starsLabel: "強度 4 / 5",
    imgSrc:
      "https://images.unsplash.com/photo-1540497077202-7c8a3999166f?w=900&h=506&fit=crop&q=80",
    imgAlt: "洗練されたトレーニングジムの設備",
  },
];
---

<section class:list={[base.section, styles.program]}>
  <div class={base.container}>
    <header class={base.sectionHeader} data-reveal>
      <span class={base.secLabel}>Program</span>
      <h2 class={base.secHeading}>PROGRAM</h2>
    </header>

    <!-- Tab navigation -->
    <div
      role="tablist"
      aria-label="プログラム選択"
      class={styles.tablist}
      data-reveal
    >
      {
        programs.map((p, i) => (
          <button
            role="tab"
            id={`tab-${p.id}`}
            aria-controls={`panel-${p.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            tabindex={i === 0 ? 0 : -1}
            class={styles.tab}
            data-tab-btn={p.id}
            type="button"
          >
            {p.label}
          </button>
        ))
      }
    </div>

    <!-- Tab panels -->
    {
      programs.map((p, i) => (
        <div
          role="tabpanel"
          id={`panel-${p.id}`}
          aria-labelledby={`tab-${p.id}`}
          class={styles.panel}
          data-tab-panel={p.id}
          data-active={i === 0 ? "" : undefined}
          data-reveal
        >
          <div class={styles.panelInner}>
            <div class={styles.panelImg}>
              <img
                src={p.imgSrc}
                alt={p.imgAlt}
                width="900"
                height="506"
                loading={i === 0 ? "eager" : "lazy"}
                onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22%3E%3ClinearGradient id=%22g%22 x2=%221%22 y2=%221%22%3E%3Cstop stop-color=%22%23c0b8ae%22/%3E%3Cstop offset=%221%22 stop-color=%22%23988c80%22/%3E%3C/linearGradient%3E%3Crect width=%22100%25%22 height=%22100%25%22 fill=%22url(%23g)%22/%3E%3C/svg%3E'"
              />
            </div>
            <div class={styles.panelBody}>
              <h3 class={styles.panelTitle}>{p.title}</h3>
              <p class={styles.panelDesc}>{p.desc}</p>
              <div class={styles.intensity}>
                <span class={styles.intensityLabel}>Intensity</span>
                <span class={styles.stars} aria-label={p.starsLabel}>
                  {p.stars}
                </span>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
