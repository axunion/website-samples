---
import styles from "./Hero.module.css";
---

<section class={styles.hero} id="home">
  <!-- Background Image with elegant overlay -->
  <div class={styles.bgWrapper}>
    <img
      src="https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1600&q=80"
      alt="Elegant fitness studio background"
      class={styles.bgImage}
      loading="eager"
      decoding="async"
    />
    <div class={styles.overlay}></div>
  </div>

  <div class={styles.content}>
    <div class={styles.inner} data-reveal>
      <p class={styles.subTitle}>STILLness & Movement</p>
      <h1 class={styles.mainTitle}>
        <span class={styles.enBrand}>STILL</span>
        <span class={styles.jaCatch}>わたしを整える、新しい習慣。</span>
        <span class={styles.jaSubCatch}>ヨガ・ピラティス・ジムがこれひとつで。</span>
      </h1>
      <div class={styles.ctaWrapper}>
        <button class={styles.ctaBtn} data-cta type="button">
          体験予約をする
        </button>
      </div>
    </div>
  </div>
  
  <div class={styles.scrollDown}>
    <span class={styles.scrollLine}></span>
    <span class={styles.scrollText}>SCROLL</span>
  </div>
</section>
